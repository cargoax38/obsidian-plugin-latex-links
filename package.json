{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"name": "Latex internal links",
	"version": "1.1.0",
	"description": "An obsidian plugin to add internal links into LaTeX expressions.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "^1.1.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
}
